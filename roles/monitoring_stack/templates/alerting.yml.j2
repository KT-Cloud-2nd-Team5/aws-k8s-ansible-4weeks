apiVersion: 1

# 1. 알림 전송 채널 설정 (Discord)
contactPoints:
  - orgId: 1
    name: 'Discord-Alert'
    receivers:
      - uid: discord_receiver_1
        type: discord
        settings:
          url: "{{ alert_webhook_url }}"

# 2. 알림 라우팅 정책
policies:
  - orgId: 1
    receiver: 'Discord-Alert'
    group_by: ['alertname', 'instance']
    group_wait: '30s'
    group_interval: '5m'
    repeat_interval: '4h'

# 3. 알림 규칙 통합 정의
groups:
  - orgId: 1
    name: 'Infrastructure-Alerts'
    folder: 'Managed-Alerts'
    interval: '1m'
    rules:
      # --- 1. 서버 다운 알림 ---
      - uid: server_down_alert
        title: 'Target Down Alert'
        condition: B  # B(Classic Condition) 결과를 따릅니다.
        data:
          - refId: A
            datasourceUid: "my-prometheus"
            relativeTimeRange: { from: 300, to: 0 }
            model:
              expr: 'sum by (instance, job) (up == 0)'
              refId: A
          - refId: B
            datasourceUid: "-100" # Grafana Expression 엔진
            model:
              type: classic_conditions
              datasource: { type: "__expr__", uid: "-100" }
              refId: B
              conditions:
                - evaluator: { params: [0], type: "gt" } # 0보다 크면 알림 발생
                  operator: { type: "and" }
                  query: { params: [A] }
                  reducer: { type: "last" }
                  type: "query"
        for: '2m'
        annotations:
          summary: "❌ 서버 다운 감지: {{ '{{' }} $labels.instance {{ '}}' }}"
          description: "{{ '{{' }} $labels.instance {{ '}}' }} 서버가 2분 이상 응답하지 않습니다. (서비스: {{ '{{' }} $labels.job {{ '}}' }})"
        labels:
          severity: critical

      # --- 2. CPU 고부하 알림 ---
      - uid: cpu_high_usage
        title: 'CPU Usage High'
        condition: B
        data:
          - refId: A
            datasourceUid: "my-prometheus"
            relativeTimeRange: { from: 300, to: 0 }
            model:
              expr: '100 - (avg by (instance) (irate(node_cpu_seconds_total{mode="idle"}[5m])) * 100)'
              refId: A
          - refId: B
            datasourceUid: "-100"
            model:
              type: classic_conditions
              datasource: { type: "__expr__", uid: "-100" }
              refId: B
              conditions:
                - evaluator: { params: [80], type: "gt" } # 80% 초과 시
                  operator: { type: "and" }
                  query: { params: [A] }
                  reducer: { type: "last" }
                  type: "query"
        for: '5m'
        annotations:
          summary: "🔥 CPU 부하 경고"
          description: "{{ '{{' }} $labels.instance {{ '}}' }} CPU 사용량 80% 초과 (현재: {{ '{{' }} $values.A.Value | printf \"%.2f\" {{ '}}' }}%)"
        labels:
          severity: warning

      # --- 3. 메모리 사용량 위험 ---
      - uid: memory_high_usage
        title: 'Memory Usage High'
        condition: B
        data:
          - refId: A
            datasourceUid: "my-prometheus"
            relativeTimeRange: { from: 300, to: 0 }
            model:
              expr: 'sum by (instance) ((node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes * 100)'
              refId: A
          - refId: B
            datasourceUid: "-100"
            model:
              type: classic_conditions
              datasource: { type: "__expr__", uid: "-100" }
              refId: B
              conditions:
                - evaluator: { params: [90], type: "gt" } # 90% 초과 시
                  operator: { type: "and" }
                  query: { params: [A] }
                  reducer: { type: "last" }
                  type: "query"
        for: '5m'
        annotations:
          summary: "⚠️ 메모리 부족 경고"
          description: "{{ '{{' }} $labels.instance {{ '}}' }} 메모리 사용률 90% 초과 (현재: {{ '{{' }} $values.A.Value | printf \"%.2f\" {{ '}}' }}%)"
        labels:
          severity: critical

      # --- 4. 디스크 공간 부족 ---
      - uid: disk_space_low
        title: 'Disk Space Low'
        condition: B
        data:
          - refId: A
            datasourceUid: "my-prometheus"
            relativeTimeRange: { from: 300, to: 0 }
            model:
              expr: 'sum by (instance) (node_filesystem_avail_bytes{mountpoint="/"} / node_filesystem_size_bytes{mountpoint="/"} * 100)'
              refId: A
          - refId: B
            datasourceUid: "-100"
            model:
              type: classic_conditions
              datasource: { type: "__expr__", uid: "-100" }
              refId: B
              conditions:
                - evaluator: { params: [15], type: "lt" } # 15% 미만 시
                  operator: { type: "and" }
                  query: { params: [A] }
                  reducer: { type: "last" }
                  type: "query"
        for: '5m'
        annotations:
          summary: "💾 디스크 공간 부족"
          description: "{{ '{{' }} $labels.instance {{ '}}' }} 루트(/) 파티션 여유 공간이 15% 미만입니다. (현재 여유량: {{ '{{' }} $values.A.Value | printf \"%.2f\" {{ '}}' }}%)"
        labels:
          severity: warning

      # --- 5. 디스크 고갈 예측 ---
      - uid: disk_will_fill_in_24h
        title: 'Disk Prediction Alert'
        condition: B
        data:
          - refId: A
            datasourceUid: "my-prometheus"
            relativeTimeRange: { from: 3600, to: 0 }
            model:
              expr: 'sum by (instance) (predict_linear(node_filesystem_free_bytes{mountpoint="/"}[1h], 24 * 3600))'
              refId: A
          - refId: B
            datasourceUid: "-100"
            model:
              type: classic_conditions
              datasource: { type: "__expr__", uid: "-100" }
              refId: B
              conditions:
                - evaluator: { params: [0], type: "lt" } # 0보다 작아질 것으로 예측 시
                  operator: { type: "and" }
                  query: { params: [A] }
                  reducer: { type: "last" }
                  type: "query"
        for: '10m'
        annotations:
          summary: "📈 디스크 고갈 위험 예측"
          description: "{{ '{{' }} $labels.instance {{ '}}' }}의 현재 디스크 사용 추세로 볼 때, 24시간 이내에 공간이 가득 찰 것으로 예측됩니다."
        labels:
          severity: warning