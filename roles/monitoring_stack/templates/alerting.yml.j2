apiVersion: 1

# 1. 알림 전송 채널 설정 (Discord)
contactPoints:
  - orgId: 1
    name: 'Discord-Alert'
    receivers:
      - uid: discord_receiver_1
        type: discord
        settings:
          url: "{{ alert_webhook_url }}"

# 2. 알림 라우팅 정책
policies:
  - orgId: 1
    receiver: 'Discord-Alert'
    group_by: ['alertname', 'instance']
    group_wait: '30s'
    group_interval: '5m'
    repeat_interval: '4h'

# 3. 알림 규칙 통합 정의
groups:
    - orgId: 1
      name: infrastructure
      folder: alert
      interval: 1m
      rules:
        - uid: dfed1dhwqv0u8c
          title: server down
          condition: C
          data:
            - refId: A
              relativeTimeRange: { from: 600, to: 0 }
              datasourceUid: my-prometheus
              model:
                expr: up == 0
                refId: A
            - refId: C
              datasourceUid: __expr__
              model:
                conditions:
                    - evaluator: { params: [0], type: gt }
                      operator: { type: and }
                      query: { params: [C] }
                      reducer: { type: last }
                      type: query
                expression: A
                refId: C
                type: threshold
          annotations:
            description: '{% raw %}서버 {{ $labels.alias }} ({{ $labels.instance }})가 응답하지 않습니다.{% endraw %}'
            summary: '{% raw %}❌ 서버 다운 감지: {{ $labels.alias }}{% endraw %}'
          labels:
            {% for ip, name in server_aliases.items() %}
            {% if ip == '{{ $labels.instance }}' %}
            alias: "{{ name }}"
            {% endif %}
            {% endfor %}
        
        - uid: efed2c4iollhca
          title: cpu 고부하
          condition: C
          data:
            - refId: A
              relativeTimeRange: { from: 600, to: 0 }
              datasourceUid: my-prometheus
              model:
                expr: 100 - (avg by (instance) (irate(node_cpu_seconds_total{mode="idle"}[5m])) * 100)
                refId: A
            - refId: C
              datasourceUid: __expr__
              model:
                conditions:
                    - evaluator: { params: [80], type: gt }
                      operator: { type: and }
                      query: { params: [C] }
                      reducer: { type: last }
                      type: query
                expression: A
                refId: C
                type: threshold
          annotations:
            description: '{% raw %}{{ $labels.alias }} 서버의 CPU 사용량이 80%를 초과했습니다. (현재: {{ $values.A.Value | printf "%.2f" }}%){% endraw %}'
            summary: "{% raw %}\U0001F525 CPU 부하 경고: {{ $labels.alias }}{% endraw %}"
          labels:
            {% for ip, name in server_aliases.items() %}
            {% if ip == '{{ $labels.instance }}' %}
            alias: "{{ name }}"
            {% endif %}
            {% endfor %}

        - uid: dfed2g53d16gwf
          title: memory 사용량 위험
          condition: C
          data:
            - refId: A
              relativeTimeRange: { from: 600, to: 0 }
              datasourceUid: my-prometheus
              model:
                expr: sum by (instance) ((node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes * 100)
                refId: A
            - refId: C
              datasourceUid: __expr__
              model:
                conditions:
                    - evaluator: { params: [90], type: gt }
                      operator: { type: and }
                      query: { params: [C] }
                      reducer: { type: last }
                      type: query
                expression: A
                refId: C
                type: threshold
          annotations:
            description: '{% raw %}서버 {{ $labels.alias }}의 메모리 사용률이 90%를 초과했습니다. (현재: {{ $values.A.Value | printf "%.2f" }}%){% endraw %}'
            summary: '{% raw %}⚠️ 메모리 부족 경고: {{ $labels.alias }}{% endraw %}'
          labels:
            {% for ip, name in server_aliases.items() %}
            {% if ip == '{{ $labels.instance }}' %}
            alias: "{{ name }}"
            {% endif %}
            {% endfor %}

        - uid: ffed2k5iwo9vkf
          title: disk 공간 부족
          condition: C
          data:
            - refId: A
              relativeTimeRange: { from: 600, to: 0 }
              datasourceUid: my-prometheus
              model:
                expr: sum by (instance) (node_filesystem_avail_bytes{mountpoint="/"} / node_filesystem_size_bytes{mountpoint="/"} * 100)
                refId: A
            - refId: C
              datasourceUid: __expr__
              model:
                conditions:
                    - evaluator: { params: [15], type: lt }
                      operator: { type: and }
                      query: { params: [C] }
                      reducer: { type: last }
                      type: query
                expression: A
                refId: C
                type: threshold
          annotations:
            description: '{% raw %}서버 {{ $labels.alias }}의 루트(/) 공간이 15% 미만입니다. (현재: {{ $values.A.Value | printf "%.2f" }}%){% endraw %}'
            summary: "{% raw %}\U0001F4BE 디스크 공간 부족: {{ $labels.alias }}{% endraw %}"
          labels:
            {% for ip, name in server_aliases.items() %}
            {% if ip == '{{ $labels.instance }}' %}
            alias: "{{ name }}"
            {% endif %}
            {% endfor %}

        - uid: cfed2o22ji41sd
          title: disk 고갈 예측
          condition: C
          data:
            - refId: A
              relativeTimeRange: { from: 600, to: 0 }
              datasourceUid: my-prometheus
              model:
                expr: sum by (instance) (predict_linear(node_filesystem_free_bytes{mountpoint="/"}[1h], 24 * 3600))
                refId: A
            - refId: C
              datasourceUid: __expr__
              model:
                conditions:
                    - evaluator: { params: [0], type: lt }
                      operator: { type: and }
                      query: { params: [C] }
                      reducer: { type: last }
                      type: query
                expression: A
                refId: C
                type: threshold
          annotations:
            description: '{% raw %}서버 {{ $labels.alias }}가 24시간 이내에 디스크 고갈될 것으로 예측됩니다.{% endraw %}'
            summary: "{% raw %}\U0001F4C8 디스크 고갈 위험 예측: {{ $labels.alias }}{% endraw %}"
          labels:
            {% for ip, name in server_aliases.items() %}
            {% if ip == '{{ $labels.instance }}' %}
            alias: "{{ name }}"
            {% endif %}
            {% endfor %}

        - uid: dfed4cmzlv5s0c
          title: 'nginx hpa '
          condition: C
          data:
            - refId: A
              relativeTimeRange: { from: 600, to: 0 }
              datasourceUid: my-prometheus
              model:
                expr: kube_horizontalpodautoscaler_status_current_replicas{horizontalpodautoscaler="web-nginx-hpa"}
                refId: A
            - refId: C
              datasourceUid: __expr__
              model:
                conditions:
                    - evaluator: { params: [2], type: gt }
                      operator: { type: and }
                      query: { params: [C] }
                      reducer: { type: last }
                      type: query
                expression: A
                refId: C
                type: threshold
          annotations:
            description: '{% raw %}Nginx 스케일 아웃 감지. 현재 레플리카: {{ $values.A.Value }}개{% endraw %}'
            summary: "{% raw %}\U0001F680 Nginx HPA 작동 알림{% endraw %}"
          labels:
            severity: warning