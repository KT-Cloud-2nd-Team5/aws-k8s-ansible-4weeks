# roles/monitoring_stack/templates/alerting.yml.j2
apiVersion: 1

# 1. 알림 전송 채널 설정 (Discord)
contactPoints:
  - orgId: 1
    name: 'Discord-Alert'
    receivers:
      - uid: discord_receiver_1
        type: discord
        settings:
          url: "{{ alert_webhook_url }}"

# 2. 알림 라우팅 정책
policies:
  - orgId: 1
    receiver: 'Discord-Alert'
    group_by: ['alertname', 'instance']
    group_wait: '30s'
    group_interval: '5m'
    repeat_interval: '4h'

# 3. 알림 규칙 통합 정의
groups:
  - orgId: 1
    name: 'Infrastructure-Alerts'
    folder: 'Managed-Alerts'
    interval: '1m'
    rules:
      # --- 1. 대상 다운 알림 (Node Exporter / App 상태) ---
      - uid: target_down_alert
        title: 'Target Down Alert'
        condition: A
        data:
          - refId: A
            datasourceUid: "my-prometheus"
            relativeTimeRange: { from: 300, to: 0 }
            model:
              expr: 'up == 0'
              refId: A
        for: '2m'
        annotations:
          summary: " [다운] 서비스 중단 감지 (IP: {{ '{{' }} $labels.instance {{ '}}' }})"
          description: "타겟: {{ '{{' }} $labels.job {{ '}}' }}\n상태: 2분 이상 응답 없음\n위치: {{ '{{' }} $labels.instance {{ '}}' }}"
        labels:
          severity: critical

      # --- 2. CPU 고부하 알림 (80% 초과) ---
      - uid: cpu_high_usage
        title: 'CPU Usage High'
        condition: A
        data:
          - refId: A
            datasourceUid: "my-prometheus"
            relativeTimeRange: { from: 300, to: 0 }
            model:
              expr: '100 - (avg by (instance) (irate(node_cpu_seconds_total{mode="idle"}[5m])) * 100) > 80'
              refId: A
        for: '5m'
        annotations:
          summary: " [CPU] 과부하 경고 (IP: {{ '{{' }} $labels.instance {{ '}}' }})"
          description: "서버 {{ '{{' }} $labels.instance {{ '}}' }}의 CPU 사용량이 80%를 초과했습니다.\n현재 수치: {{ '{{' }} $values.A.Value | printf \"%.2f\" {{ '}}' }}%"
        labels:
          severity: warning

      # --- 3. 메모리 사용량 위험 (90% 초과) ---
      - uid: memory_high_usage
        title: 'Memory Usage High'
        condition: A
        data:
          - refId: A
            datasourceUid: "my-prometheus"
            relativeTimeRange: { from: 300, to: 0 }
            model:
              expr: '((node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes) * 100 > 90'
              refId: A
        for: '5m'
        annotations:
          summary: " [메모리] 고갈 위기 (IP: {{ '{{' }} $labels.instance {{ '}}' }})"
          description: "서버 {{ '{{' }} $labels.instance {{ '}}' }}의 여유 메모리가 부족합니다.\n현재 사용률: {{ '{{' }} $values.A.Value | printf \"%.2f\" {{ '}}' }}%"
        labels:
          severity: critical

      # --- 4. 디스크 공간 부족 (15% 미만) ---
      - uid: disk_space_low
        title: 'Disk Space Low'
        condition: A
        data:
          - refId: A
            datasourceUid: "my-prometheus"
            relativeTimeRange: { from: 300, to: 0 }
            model:
              expr: '(node_filesystem_avail_bytes{mountpoint="/"} / node_filesystem_size_bytes{mountpoint="/"}) * 100 < 15'
              refId: A
        for: '5m'
        annotations:
          summary: " [디스크] 공간 부족 (IP: {{ '{{' }} $labels.instance {{ '}}' }})"
          description: "서버 {{ '{{' }} $labels.instance {{ '}}' }}의 루트(/) 파티션 용량이 15% 미만입니다.\n현재 여유: {{ '{{' }} $values.A.Value | printf \"%.2f\" {{ '}}' }}%"
        labels:
          severity: warning

      # --- 5. Nginx 5xx 에러 발생 (서비스 장애) ---
      - uid: nginx_high_5xx_errors
        title: 'Nginx High 5xx Errors'
        condition: A
        data:
          - refId: A
            datasourceUid: "my-prometheus"
            relativeTimeRange: { from: 300, to: 0 }
            model:
              expr: 'sum by (instance) (rate(nginx_http_requests_total{status=~"5.."}[5m])) > 0'
              refId: A
        for: '1m'
        annotations:
          summary: " [Nginx] 서버 에러 감지 (IP: {{ '{{' }} $labels.instance {{ '}}' }})"
          description: "서버 {{ '{{' }} $labels.instance {{ '}}' }}에서 5xx 응답이 발생 중입니다.\n백엔드 파드 상태를 확인하세요."
        labels:
          severity: critical

      # --- 6. MySQL 너무 많은 연결 (리소스 고갈 방지) ---
      - uid: mysql_too_many_connections
        title: 'MySQL Too Many Connections'
        condition: A
        data:
          - refId: A
            datasourceUid: "my-prometheus"
            relativeTimeRange: { from: 300, to: 0 }
            model:
              expr: '(mysql_global_status_threads_connected / mysql_global_variables_max_connections) * 100 > 80'
              refId: A
        for: '2m'
        annotations:
          summary: " [MySQL] 연결 수 위험 (IP: {{ '{{' }} $labels.instance {{ '}}' }})"
          description: "DB {{ '{{' }} $labels.instance {{ '}}' }}의 최대 연결 수 대비 80%를 초과했습니다.\n현재 비율: {{ '{{' }} $values.A.Value | printf \"%.2f\" {{ '}}' }}%"
        labels:
          severity: warning

      # --- 7. 디스크 고갈 예측 (24시간 내 만료 예상) ---
      - uid: disk_will_fill_in_24h
        title: 'Disk Prediction Alert'
        condition: A
        data:
          - refId: A
            datasourceUid: "my-prometheus"
            relativeTimeRange: { from: 3600, to: 0 }
            model:
              expr: 'predict_linear(node_filesystem_free_bytes{mountpoint="/"}[1h], 24 * 3600) < 0'
              refId: A
        for: '10m'
        annotations:
          summary: " [예측] 디스크 고갈 위험 (IP: {{ '{{' }} $labels.instance {{ '}}' }})"
          description: "인스턴스 {{ '{{' }} $labels.instance {{ '}}' }}의 사용 추세 분석 결과, 24시간 내 디스크가 가득 찰 예정입니다."
        labels:
          severity: warning