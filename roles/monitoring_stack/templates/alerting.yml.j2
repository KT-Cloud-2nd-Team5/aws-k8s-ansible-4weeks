apiVersion: 1

# 1. 알림 전송 채널 설정 (Discord)
contactPoints:
  - orgId: 1
    name: 'Discord-Alert'
    receivers:
      - uid: discord_receiver_1
        type: discord
        settings:
          url: "{{ alert_webhook_url }}"

# 2. 알림 라우팅 정책
policies:
  - orgId: 1
    receiver: 'Discord-Alert'
    group_by: ['alertname', 'instance']
    group_wait: '5s'       # 테스트를 위해 대기 시간 최소화
    group_interval: '10s'
    repeat_interval: '1h'

# 3. 알림 규칙 통합 정의
groups:
  - orgId: 1
    name: infrastructure_test
    folder: alert
    interval: 10s         # 10초마다 상태 체크
    rules:
      # --- 1. [테스트] 서버 가동 확인 (서버가 살아있으면 알림 발생) ---
      - uid: dfed1dhwqv0u8c
        title: "[TEST] Server Up Alert"
        condition: C
        data:
          - refId: A
            relativeTimeRange: { from: 600, to: 0 }
            datasourceUid: my-prometheus
            model:
              expr: sum by (instance) (up)
              refId: A
          - refId: B
            datasourceUid: __expr__
            model: { expression: A, reducer: last, type: reduce, refId: B }
          - refId: C
            datasourceUid: __expr__
            model:
              expression: B
              type: threshold
              refId: C
              conditions:
                - evaluator: { params: [0.5], type: gt } # 1(정상)이면 알람 발생 (테스트용)
                  operator: { type: and }
                  query: { params: [B] }
                  reducer: { type: last }
                  type: query
        noDataState: NoData
        execErrState: OK
        for: 5s
        annotations:
          description: '서버 {{ '{{' }} $labels.instance {{ '}}' }} 가 현재 가동 중입니다. (테스트 알람)'
          summary: >-
            ❌ [TEST] 서버 감지: 
            {{ '{{' }} if eq $labels.instance "10.0.2.235:9100" {{ '}}' }} Master Node
            {{ '{{' }} else if eq $labels.instance "10.0.1.90:9100" {{ '}}' }} Web Node-01
            {{ '{{' }} else if eq $labels.instance "10.0.3.206:9100" {{ '}}' }} Web Node-02
            {{ '{{' }} else if eq $labels.instance "10.0.2.222:9100" {{ '}}' }} DB Node
            {{ '{{' }} else {{ '}}' }} {{ '{{' }} $labels.instance {{ '}}' }} {{ '{{' }} end {{ '}}' }}

      # --- 2. [테스트] CPU 고부하 (1% 초과 시 알람) ---
      - uid: efed2c4iollhca
        title: "[TEST] CPU High Usage"
        condition: C
        data:
          - refId: A
            relativeTimeRange: { from: 600, to: 0 }
            datasourceUid: my-prometheus
            model:
              expr: 100 - (avg by (instance) (irate(node_cpu_seconds_total{mode="idle"}[5m])) * 100)
              refId: A
          - refId: B
            datasourceUid: __expr__
            model: { expression: A, reducer: last, type: reduce, refId: B }
          - refId: C
            datasourceUid: __expr__
            model:
              expression: B
              type: threshold
              refId: C
              conditions:
                - evaluator: { params: [1], type: gt } # 1%만 넘어도 알람
                  operator: { type: and }
                  query: { params: [B] }
                  reducer: { type: last }
                  type: query
        for: 5s
        annotations:
          description: '서버 {{ '{{' }} $labels.instance {{ '}}' }} CPU 사용량 {{ '{{' }} $values.B.Value | printf "%.2f" {{ '}}' }}% (테스트)'
          summary: >-
            🔥 [TEST] CPU 부하: 
            {{ '{{' }} if eq $labels.instance "10.0.2.235:9100" {{ '}}' }} Master Node
            {{ '{{' }} else if eq $labels.instance "10.0.1.90:9100" {{ '}}' }} Web Node-01
            {{ '{{' }} else if eq $labels.instance "10.0.3.206:9100" {{ '}}' }} Web Node-02
            {{ '{{' }} else if eq $labels.instance "10.0.2.222:9100" {{ '}}' }} DB Node
            {{ '{{' }} else {{ '}}' }} {{ '{{' }} $labels.instance {{ '}}' }} {{ '{{' }} end {{ '}}' }}

      # --- 3. [테스트] 메모리 사용량 (5% 초과 시 알람) ---
      - uid: dfed2g53d16gwf
        title: "[TEST] Memory High Usage"
        condition: C
        data:
          - refId: A
            relativeTimeRange: { from: 600, to: 0 }
            datasourceUid: my-prometheus
            model:
              expr: sum by (instance) ((node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes * 100)
              refId: A
          - refId: B
            datasourceUid: __expr__
            model: { expression: A, reducer: last, type: reduce, refId: B }
          - refId: C
            datasourceUid: __expr__
            model: { expression: B, type: threshold, refId: C, conditions: [{ evaluator: { params: [5], type: gt }, operator: { type: and }, query: { params: [B] }, reducer: { type: last }, type: query }] }
        for: 5s
        annotations:
          description: '서버 {{ '{{' }} $labels.instance {{ '}}' }} 메모리 사용률 {{ '{{' }} $values.B.Value | printf "%.2f" {{ '}}' }}% (테스트)'
          summary: >-
            ⚠️ [TEST] 메모리 경고: 
            {{ '{{' }} if eq $labels.instance "10.0.2.235:9100" {{ '}}' }} Master Node
            {{ '{{' }} else if eq $labels.instance "10.0.1.90:9100" {{ '}}' }} Web Node-01
            {{ '{{' }} else if eq $labels.instance "10.0.3.206:9100" {{ '}}' }} Web Node-02
            {{ '{{' }} else if eq $labels.instance "10.0.2.222:9100" {{ '}}' }} DB Node
            {{ '{{' }} else {{ '}}' }} {{ '{{' }} $labels.instance {{ '}}' }} {{ '{{' }} end {{ '}}' }}

      # --- 4. [테스트] 디스크 공간 (95% 미만 여유 시 알람 - 즉, 거의 무조건 발생) ---
      - uid: ffed2k5iwo9vkf
        title: "[TEST] Disk Space Low"
        condition: C
        data:
          - refId: A
            relativeTimeRange: { from: 600, to: 0 }
            datasourceUid: my-prometheus
            model:
              expr: sum by (instance) (node_filesystem_avail_bytes{mountpoint="/"} / node_filesystem_size_bytes{mountpoint="/"} * 100)
              refId: A
          - refId: B
            datasourceUid: __expr__
            model: { expression: A, reducer: last, type: reduce, refId: B }
          - refId: C
            datasourceUid: __expr__
            model: { expression: B, type: threshold, refId: C, conditions: [{ evaluator: { params: [95], type: lt }, operator: { type: and }, query: { params: [B] }, reducer: { type: last }, type: query }] }
        for: 5s
        annotations:
          description: '서버 {{ '{{' }} $labels.instance {{ '}}' }} 디스크 여유량 {{ '{{' }} $values.B.Value | printf "%.2f" {{ '}}' }}% (테스트)'
          summary: >-
            💾 [TEST] 디스크 경고: 
            {{ '{{' }} if eq $labels.instance "10.0.2.235:9100" {{ '}}' }} Master Node
            {{ '{{' }} else if eq $labels.instance "10.0.1.90:9100" {{ '}}' }} Web Node-01
            {{ '{{' }} else if eq $labels.instance "10.0.3.206:9100" {{ '}}' }} Web Node-02
            {{ '{{' }} else if eq $labels.instance "10.0.2.222:9100" {{ '}}' }} DB Node
            {{ '{{' }} else {{ '}}' }} {{ '{{' }} $labels.instance {{ '}}' }} {{ '{{' }} end {{ '}}' }}

      # --- 5. [테스트] Nginx HPA (파드가 0개 이상이면 알람) ---
      - uid: dfed4cmzlv5s0c
        title: "[TEST] Nginx HPA Scale"
        condition: C
        for: 5s
        data:
          - refId: A
            relativeTimeRange: { from: 600, to: 0 }
            datasourceUid: my-prometheus
            model:
              expr: kube_horizontalpodautoscaler_status_current_replicas{horizontalpodautoscaler="web-nginx-hpa"}
              instant: true
              refId: A
          - refId: C
            datasourceUid: __expr__
            model:
              expression: A
              type: threshold
              refId: C
              conditions:
                - evaluator: { params: [0], type: gt } # 파드가 1개만 있어도 즉시 발생
                  operator: { type: and }
                  reducer: { type: last }
                  type: query
        annotations:
          description: 'Nginx HPA 작동 테스트 (현재 복제본: {{ '{{' }} $values.A.Value {{ '}}' }}개)'
          summary: "🚀 [TEST] Nginx 스케일 감지"