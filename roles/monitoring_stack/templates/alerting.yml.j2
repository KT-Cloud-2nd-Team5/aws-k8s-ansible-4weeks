apiVersion: 1

# 1. 알림 전송 채널 설정 (Discord)
contactPoints:
  - orgId: 1
    name: 'Discord-Alert'
    receivers:
      - uid: discord_receiver_1
        type: discord
        settings:
          url: "{{ alert_webhook_url }}"

# 2. 알림 라우팅 정책
policies:
  - orgId: 1
    receiver: 'Discord-Alert'
    group_by: ['alertname', 'instance']
    group_wait: '30s'
    group_interval: '5m'
    repeat_interval: '4h'

# 3. 알림 규칙 통합 정의
groups:
  - orgId: 1
    name: infrastructure
    folder: alert
    interval: 1m
    rules:
      # --- 1. 서버 다운 알림 ---
      - uid: dfed1dhwqv0u8c
        title: server down
        condition: C
        data:
          - refId: A
            relativeTimeRange: { from: 600, to: 0 }
            datasourceUid: my-prometheus
            model:
              expr: up == 0
              refId: A
          - refId: C
            datasourceUid: __expr__
            model:
              type: classic_conditions
              refId: C
              conditions:
                - evaluator: { params: [0], type: gt }
                  operator: { type: and }
                  query: { params: [A] } # 원본 데이터 A를 참조해야 함
                  reducer: { type: last }
                  type: query
        noDataState: NoData
        execErrState: OK
        for: 1m
        annotations:
          description: '서버 {{ '{{' }} $labels.instance {{ '}}' }} (서비스: {{ '{{' }} $labels.job {{ '}}' }})가 1분 이상 응답하지 않습니다.'
          summary: '❌ 서버 다운 감지: {{ '{{' }} $labels.instance {{ '}}' }}'
        isPaused: false
        notification_settings:
          receiver: Discord-Alert

      # --- 2. CPU 고부하 알림 ---
      - uid: efed2c4iollhca
        title: cpu 고부하
        condition: C
        data:
          - refId: A
            relativeTimeRange: { from: 600, to: 0 }
            datasourceUid: my-prometheus
            model:
              expr: 100 - (avg by (instance) (irate(node_cpu_seconds_total{mode="idle"}[5m])) * 100)
              refId: A
          - refId: C
            datasourceUid: __expr__
            model:
              type: classic_conditions
              refId: C
              conditions:
                - evaluator: { params: [80], type: gt }
                  operator: { type: and }
                  query: { params: [A] }
                  reducer: { type: last }
                  type: query
        for: 5m
        annotations:
          description: '{{ '{{' }} $labels.instance {{ '}}' }} 서버의 CPU 사용량이 80%를 초과했습니다. (현재: {{ '{{' }} $values.A.Value | printf "%.2f" {{ '}}' }}%)'
          summary: "🔥 CPU 부하 경고: {{ '{{' }} $labels.instance {{ '}}' }}"
        isPaused: false
        notification_settings:
          receiver: Discord-Alert

      # --- 3. 메모리 사용량 위험 ---
      - uid: dfed2g53d16gwf
        title: memory 사용량 위험
        condition: C
        data:
          - refId: A
            relativeTimeRange: { from: 600, to: 0 }
            datasourceUid: my-prometheus
            model:
              expr: sum by (instance) ((node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes * 100)
              refId: A
          - refId: C
            datasourceUid: __expr__
            model:
              type: classic_conditions
              refId: C
              conditions:
                - evaluator: { params: [90], type: gt }
                  operator: { type: and }
                  query: { params: [A] }
                  reducer: { type: last }
                  type: query
        for: 5m
        annotations:
          description: '서버 {{ '{{' }} $labels.instance {{ '}}' }}의 메모리 사용률이 90%를 초과했습니다. (현재: {{ '{{' }} $values.A.Value | printf "%.2f" {{ '}}' }}%)'
          summary: '⚠️ 메모리 부족 경고: {{ '{{' }} $labels.instance {{ '}}' }}'
        isPaused: false
        notification_settings:
          receiver: Discord-Alert

      # --- 4. 디스크 공간 부족 ---
      - uid: ffed2k5iwo9vkf
        title: disk 공간 부족
        condition: C
        data:
          - refId: A
            relativeTimeRange: { from: 600, to: 0 }
            datasourceUid: my-prometheus
            model:
              expr: sum by (instance) (node_filesystem_avail_bytes{mountpoint="/"} / node_filesystem_size_bytes{mountpoint="/"} * 100)
              refId: A
          - refId: C
            datasourceUid: __expr__
            model:
              type: classic_conditions
              refId: C
              conditions:
                - evaluator: { params: [15], type: lt }
                  operator: { type: and }
                  query: { params: [A] }
                  reducer: { type: last }
                  type: query
        for: 5m
        annotations:
          description: '서버 {{ '{{' }} $labels.instance {{ '}}' }}의 루트(/) 파티션 여유 공간이 15% 미만입니다. (현재 여유량: {{ '{{' }} $values.A.Value | printf "%.2f" {{ '}}' }}%)'
          summary: "💾 디스크 공간 부족: {{ '{{' }} $labels.instance {{ '}}' }}"
        isPaused: false
        notification_settings:
          receiver: Discord-Alert

      # --- 5. 디스크 고갈 예측 ---
      - uid: cfed2o22ji41sd
        title: disk 고갈 예측
        condition: C
        data:
          - refId: A
            relativeTimeRange: { from: 3600, to: 0 }
            datasourceUid: my-prometheus
            model:
              expr: sum by (instance) (predict_linear(node_filesystem_free_bytes{mountpoint="/"}[1h], 24 * 3600))
              refId: A
          - refId: C
            datasourceUid: __expr__
            model:
              type: classic_conditions
              refId: C
              conditions:
                - evaluator: { params: [0], type: lt }
                  operator: { type: and }
                  query: { params: [A] }
                  reducer: { type: last }
                  type: query
        for: 10m
        annotations:
          description: '서버 {{ '{{' }} $labels.instance {{ '}}' }}의 현재 디스크 사용 추세로 볼 때, 24시간 이내에 공간이 가득 찰 것으로 예측됩니다.'
          summary: "📈 디스크 고갈 위험 예측: {{ '{{' }} $labels.instance {{ '}}' }}"
        isPaused: false
        notification_settings:
          receiver: Discord-Alert

      # --- 6. Nginx HPA 알림 ---
      - uid: dfed4cmzlv5s0c
        title: 'nginx hpa '
        condition: C
        data:
          - refId: A
            relativeTimeRange: { from: 600, to: 0 }
            datasourceUid: my-prometheus
            model:
              expr: kube_horizontalpodautoscaler_status_current_replicas{horizontalpodautoscaler="web-nginx-hpa"}
              refId: A
          - refId: C
            datasourceUid: __expr__
            model:
              type: classic_conditions
              refId: C
              conditions:
                - evaluator: { params: [2], type: gt }
                  operator: { type: and }
                  query: { params: [A] }
                  reducer: { type: last }
                  type: query
        for: 1m
        annotations:
          description: 'Nginx 파드 수가 늘어났습니다. 현재 복제본 수: {{ '{{' }} $values.A.Value {{ '}}' }}개.'
          summary: "🚀 Nginx 스케일 아웃 감지 (HPA 작동)"
        isPaused: false
        notification_settings:
          receiver: Discord-Alert