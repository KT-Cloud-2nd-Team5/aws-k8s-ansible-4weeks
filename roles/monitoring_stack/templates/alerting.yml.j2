apiVersion: 1

# 1. 알림 전송 채널 설정
contactPoints:
  - orgId: 1
    name: Discord-Alert
    receivers:
      - uid: discord_receiver_1
        type: discord
        settings:
          url: '{{ alert_webhook_url }}'
          message: "{{ '{{' }} template \"discord_template_group\" . {{ '}}' }}"

# 2. 알림 라우팅 정책
policies:
  - orgId: 1
    receiver: Discord-Alert
    group_by: [alertname, nodename]
    group_wait: 30s
    group_interval: 5m
    repeat_interval: 4h

# 3. 알림 규칙 통합 정의
groups:
  - orgId: 1
    name: infrastructure
    folder: alert
    interval: 1m
    rules:
      # --- 1. 서버 다운 알람 ---
      - uid: server_health_check_uid
        title: Server Down Alert
        condition: C
        for: 1m
        data:
          - refId: A
            relativeTimeRange: {from: 600, to: 0}
            datasourceUid: my-prometheus
            model:
              expr: |
                avg by (alias, node) (
                  label_replace(label_replace(avg by (instance, alias) (up{job="kubernetes-nodes"}), "node", "$1", "instance", "ip-([0-9-]+)"), "node", "$1.$2.$3.$4", "node", "([0-9]+)-([0-9]+)-([0-9]+)-([0-9]+)")
                  or label_replace(label_replace(avg by (instance) (up{job="monitoring-server-node"}), "alias", "monitoring-server", "", ""), "node", "$1", "instance", "([^:]+):.*")
                )
          - refId: B
            datasourceUid: __expr__
            model: {expression: A, reducer: last, type: reduce}
          - refId: C
            datasourceUid: __expr__
            model:
              expression: B
              type: threshold
              conditions:
                - evaluator: {params: [1], type: lt}
                  operator: {type: and}
                  query: {params: [B]}
                  reducer: {type: last}
                  type: query
        annotations:
          summary: "🚨 서버 다운 감지: {{ '{{' }} $labels.alias {{ '}}' }}"
          description: "대상 서버: {{ '{{' }} $labels.alias {{ '}}' }} (IP: {{ '{{' }} $labels.node {{ '}}' }})\n서버의 응답이 없습니다. 상태를 확인하세요."

      # --- 2. CPU 사용량 위험 ---
      - uid: cpu_usage_alert_uid
        title: CPU 사용량 위험
        condition: C
        for: 1m
        data:
          - refId: A
            relativeTimeRange: {from: 600, to: 0}
            datasourceUid: my-prometheus
            model:
              expr: |
                100 - (
                  avg by (alias, node) (
                    label_replace(irate(node_cpu_seconds_total{mode="idle"}[5m]), "node", "$1", "instance", "([^:]+):.*")
                    * on(node) group_left(alias) (
                      label_replace(label_replace(avg by (instance, alias) (up{job="kubernetes-nodes"}), "node", "$1", "instance", "ip-([0-9-]+)"), "node", "$1.$2.$3.$4", "node", "([0-9]+)-([0-9]+)-([0-9]+)-([0-9]+)")
                      or label_replace(label_replace(avg by (instance) (up{job="monitoring-server-node"}), "alias", "monitoring-server", "", ""), "node", "$1", "instance", "([^:]+):.*")
                    )
                  ) * 100
                )
          - refId: B
            datasourceUid: __expr__
            model: {expression: A, reducer: last, type: reduce}
          - refId: C
            datasourceUid: __expr__
            model:
              expression: B
              type: threshold
              conditions:
                - evaluator: {params: [80], type: gt}
                  operator: {type: and}
                  query: {params: [B]}
                  reducer: {type: last}
                  type: query
        annotations:
          summary: "🔥 CPU 과부하 경고: {{ '{{' }} $labels.alias {{ '}}' }}"
          description: "대상 서버: {{ '{{' }} $labels.alias {{ '}}' }} (IP: {{ '{{' }} $labels.node {{ '}}' }})\n현재 CPU 사용률: {{ '{{' }} $values.B.Value | printf \"%.2f\" {{ '}}' }}%"

      # --- 3. 메모리 사용량 위험 ---
      - uid: dfed2g53d16gwf
        title: memory 사용량 위험
        condition: C
        for: 5m
        data:
          - refId: A
            relativeTimeRange: {from: 600, to: 0}
            datasourceUid: my-prometheus
            model:
              expr: |
                avg by (alias, node) (
                  label_replace((node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes * 100, "node", "$1", "instance", "([^:]+):.*")
                  * on(node) group_left(alias) (
                    label_replace(label_replace(avg by (instance, alias) (up{job="kubernetes-nodes"}), "node", "$1", "instance", "ip-([0-9-]+)"), "node", "$1.$2.$3.$4", "node", "([0-9]+)-([0-9]+)-([0-9]+)-([0-9]+)")
                    or label_replace(label_replace(avg by (instance) (up{job="monitoring-server-node"}), "alias", "monitoring-server", "", ""), "node", "$1", "instance", "([^:]+):.*")
                  )
                )
          - refId: B
            datasourceUid: __expr__
            model: {expression: A, reducer: last, type: reduce}
          - refId: C
            datasourceUid: __expr__
            model:
              expression: B
              type: threshold
              conditions:
                - evaluator: {params: [90], type: gt}
                  operator: {type: and}
                  query: {params: [B]}
                  reducer: {type: last}
                  type: query
        annotations:
          summary: "⚠️ [메모리 부족] {{ '{{' }} $labels.alias {{ '}}' }}"
          description: "대상 서버: {{ '{{' }} $labels.alias {{ '}}' }} (IP: {{ '{{' }} $labels.node {{ '}}' }})\n현재 메모리 사용률: {{ '{{' }} $values.B.Value | printf \"%.2f\" {{ '}}' }}%"

      # --- 4. 디스크 용량 부족 위험 ---
      - uid: disk_usage_alert_uid
        title: "disk 사용량 위험"
        condition: C
        for: 2m
        data:
          - refId: A
            relativeTimeRange: {from: 600, to: 0}
            datasourceUid: my-prometheus
            model:
              expr: |
                avg by (alias, node) (
                  label_replace((node_filesystem_avail_bytes{mountpoint="/"} / node_filesystem_size_bytes{mountpoint="/"}) * 100, "node", "$1", "instance", "([^:]+):.*")
                  * on(node) group_left(alias) (
                    label_replace(label_replace(avg by (instance, alias) (up{job="kubernetes-nodes"}), "node", "$1", "instance", "ip-([0-9-]+)"), "node", "$1.$2.$3.$4", "node", "([0-9]+)-([0-9]+)-([0-9]+)-([0-9]+)")
                    or label_replace(label_replace(avg by (instance) (up{job="monitoring-server-node"}), "alias", "monitoring-server", "", ""), "node", "$1", "instance", "([^:]+):.*")
                  )
                )
          - refId: B
            datasourceUid: __expr__
            model: {expression: A, reducer: last, type: reduce}
          - refId: C
            datasourceUid: __expr__
            model:
              expression: B
              type: threshold
              conditions:
                - evaluator: {params: [20], type: lt}
                  operator: {type: and}
                  query: {params: [B]}
                  reducer: {type: last}
                  type: query
        annotations:
          summary: "⚠️ 디스크 용량 부족 경고: {{ '{{' }} $labels.alias {{ '}}' }}"
          description: "대상 서버: {{ '{{' }} $labels.alias {{ '}}' }}\n남은 공간: {{ '{{' }} $values.B.Value | printf \"%.2f\" {{ '}}' }}%"

      # --- 5. 디스크 고갈 예측 ---
      - uid: disk_prediction_alert_uid
        title: "disk 고갈 예측 (24시간 내)"
        condition: C
        for: 5m
        data:
          - refId: A
            relativeTimeRange: {from: 3600, to: 0}
            datasourceUid: my-prometheus
            model:
              expr: |
                sum by (alias, node) (
                  label_replace(predict_linear(node_filesystem_free_bytes{mountpoint="/"}[1h], 24 * 3600), "node", "$1", "instance", "([^:]+):.*")
                  * on(node) group_left(alias) (
                    label_replace(label_replace(avg by (instance, alias) (up{job="kubernetes-nodes"}), "node", "$1", "instance", "ip-([0-9-]+)"), "node", "$1.$2.$3.$4", "node", "([0-9]+)-([0-9]+)-([0-9]+)-([0-9]+)")
                    or label_replace(label_replace(avg by (instance) (up{job="monitoring-server-node"}), "alias", "monitoring-server", "", ""), "node", "$1", "instance", "([^:]+):.*")
                  )
                )
          - refId: B
            datasourceUid: __expr__
            model: {expression: A, reducer: last, type: reduce}
          - refId: C
            datasourceUid: __expr__
            model:
              expression: B
              type: threshold
              conditions:
                - evaluator: {params: [0], type: lt}
                  operator: {type: and}
                  query: {params: [B]}
                  reducer: {type: last}
                  type: query
        annotations:
          summary: "🚨 디스크 고갈 예측: {{ '{{' }} $labels.alias {{ '}}' }}"
          description: "서버 {{ '{{' }} $labels.alias {{ '}}' }}의 디스크가 24시간 이내 고갈될 예정입니다."

      # --- 6. Nginx HPA ---
      - uid: dfed4cmzlv5s0c
        title: "nginx hpa"
        condition: C
        for: 1m
        data:
          - refId: A
            relativeTimeRange: {from: 600, to: 0}
            datasourceUid: my-prometheus
            model:
              expr: "kube_horizontalpodautoscaler_status_current_replicas{horizontalpodautoscaler='web-nginx-hpa', namespace='default'}"
          - refId: B
            datasourceUid: __expr__
            model: {expression: A, reducer: last, type: reduce}
          - refId: C
            datasourceUid: __expr__
            model:
              expression: B
              type: threshold
              conditions:
                - evaluator: {params: [2], type: gt}
                  operator: {type: and}
                  query: {params: [B]}
                  reducer: {type: last}
                  type: query
        annotations:
          summary: "🚀 Nginx 스케일 아웃 감지 ({{ '{{' }} $labels.horizontalpodautoscaler {{ '}}' }})"
          description: "현재 복제본 수: {{ '{{' }} $values.B.Value | printf \"%.0f\" {{ '}}' }}개"