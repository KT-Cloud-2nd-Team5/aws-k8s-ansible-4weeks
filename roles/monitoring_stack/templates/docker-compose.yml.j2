# roles/monitoring_stack/templates/docker-compose.yml.j2
services:
  # Prometheus
  prometheus:
    image: prom/prometheus:latest
    container_name: prometheus
    user: "root"  # 로컬 디렉토리 권한 문제를 방지하기 위해 root 사용
    volumes:
      - {{ monitoring_dir }}/prometheus.yml:/etc/prometheus/prometheus.yml
      - prometheus_data:/prometheus
    command:
      - '--config.file=/etc/prometheus/prometheus.yml'
      - '--storage.tsdb.path=/prometheus'
      - '--storage.tsdb.retention.time={{ prometheus_retention_time }}' # 변수 처리 (15d)
      - '--storage.tsdb.retention.size={{ prometheus_retention_size }}' # 변수 처리 (5GB)
    
   # 리소스 제한
    deploy:
      resources:
        limits:
          memory: 512M
    restart: unless-stopped
    ports:
      - "{{ prometheus_port }}:9090"

  # Grafana
  grafana:
    image: grafana/grafana:latest
    container_name: grafana
    ports:
      - "{{ grafana_port }}:3000"
    environment:
      - GF_SECURITY_ADMIN_PASSWORD={{ grafana_admin_password }}
      - GF_USERS_ALLOW_SIGN_UP=false # 보안을 위해 회원가입 방지
    volumes:
      - grafana_data:/var/lib/grafana
      # 자동 설정을 위한 Provisioning 볼륨 연결
      # 폴더 단위 마운트
      - {{ monitoring_dir }}/provisioning:/etc/grafana/provisioning
      - {{ monitoring_dir }}/dashboards:/var/lib/grafana/dashboards
    # 리소스 제한
    deploy:
      resources:
        limits:
          memory: 400M
    restart: unless-stopped
    depends_on:
      - prometheus

  # Node-Exporter
  node-exporter:
    image: prom/node-exporter:latest
    container_name: node-exporter
    # 호스트의 실제 리소스를 읽기 위해 루트 권한 및 네트워크 설정 필요
    volumes:
      - /proc:/host/proc:ro
      - /sys:/host/sys:ro
      - /:/rootfs:ro
    command:
      - '--path.procfs=/host/proc'
      - '--path.sysfs=/host/sys'
      - '--collector.filesystem.ignored-mount-points=^/(sys|proc|dev|host|etc)($$|/)'
    restart: unless-stopped

volumes:
  prometheus_data:
  grafana_data:
