global:
  scrape_interval: 30s
  evaluation_interval: 30s
  external_labels:
    monitor: 'monitoring-server'

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  - job_name: 'node-exporter'
    static_configs:
      - targets: ['node-exporter:9100']
        labels:
          instance: 'monitoring-server'
{% if groups['target_servers'] is defined %}
      - targets:
{% for host in groups['target_servers'] %}
        - "{{ hostvars[host].ansible_host }}:9100"
{% endfor %}
{% endif %}

  - job_name: 'mysql'
    static_configs:
{% if groups['db_server'] is defined %}
      - targets:
{% for host in groups['db_server'] %}
        - "{{ hostvars[host].ansible_host }}:30104"
{% endfor %}
{% endif %}
